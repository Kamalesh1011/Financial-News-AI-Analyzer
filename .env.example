# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/finnews
MONGODB_DB=finnews

# Market Data APIs
FINNHUB_API_KEY=xx
NEWSAPI_API_KEY=xx
COINGECKO_API_KEY=CG-xx

# LLM APIs
OPENROUTER_API_KEY=sk-or-v1-xx
NIM_API_KEY=vapi-xx

# Alert Channels
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=xx@gmail.com
SMTP_PASS=your_app_password
ALERT_EMAIL_TO=xx@gmail.com@example.com

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
NEWS_FETCH_INTERVAL_MINUTES=5
MARKET_FETCH_INTERVAL_MINUTES=2
SENTIMENT_BATCH_SIZE=15
ALERT_COOLDOWN_MINUTES=30
HIGH_RISK_CONFIDENCE_THRESHOLD=0.75
MEDIUM_RISK_CONFIDENCE_THRESHOLD=0.55
SENTIMENT_CONFIDENCE_THRESHOLD=0.6