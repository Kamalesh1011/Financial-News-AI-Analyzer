{
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install --prefix frontend",
  "buildCommand": "npm run build --prefix frontend",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/cron/collect-news",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/collect-market",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/analyze-sentiment",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/map-impact",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/check-alerts",
      "schedule": "0 8 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/health",
      "dest": "api/index.py"
    },
    {
      "src": "/ready",
      "dest": "api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ]
}
