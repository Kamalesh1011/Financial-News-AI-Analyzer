{
  "name": "plotcode-docx-generator",
  "version": "2.0.0",
  "description": "Configurable DOCX document generator for project build plans",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "generate": "tsx src/index.ts --config src/config/sample.json",
    "generate:custom": "tsx src/index.ts --config"
  },
  "dependencies": {
    "docx": "^9.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}